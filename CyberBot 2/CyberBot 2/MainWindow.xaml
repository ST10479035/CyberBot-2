<Window x:Class="CyberBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot" Height="680" Width="550"
        Background="#0F172A" MinHeight="500" MinWidth="400" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E293B" CornerRadius="8" Padding="10" Margin="0,0,0,15">
            <TextBlock x:Name="lblStatusHeader" Text="Welcome! Please initialize credentials below."
                       Foreground="#22D3EE" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
        </Border>

        <ScrollViewer Grid.Row="1" x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
            <Border Background="#16141C" CornerRadius="8" Padding="10">
                <StackPanel x:Name="ChatStack" VerticalAlignment="Bottom"/>
            </Border>
        </ScrollViewer>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="txtUserInput" Grid.Column="0" Height="35" Padding="8,5,8,5"
                     FontSize="14" Background="#1E293B" Foreground="White" BorderBrush="#334155"
                     CaretBrush="White" VerticalContentAlignment="Center" KeyDown="TxtUserInput_KeyDown"/>

            <Button x:Name="btnSend" Grid.Column="1" Content="SEND" Width="90" Margin="10,0,0,0"
                    Background="#22D3EE" Foreground="#0F172A" FontWeight="Bold" FontSize="13"
                    Click="BtnSend_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Grid>
</Window>